DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DBNAME
# Optional: set to false when Postgres presents a cert trusted by the default CA store (stricter TLS).
# Omit or true for typical Railway/managed Postgres (default matches previous behavior).
# DATABASE_SSL_TRUST_SERVER_CERTIFICATE=false
# JWT signing key (required). Use JWT_SECRET or Jwt__Secret — never commit real values to appsettings.json.
JWT_SECRET=replace-with-strong-random-secret
JWT_ISSUER=circlehealing
JWT_AUDIENCE=circlehealing-client
FRONTEND_ORIGIN=https://your-frontend-service.up.railway.app
# For EF migrations locally: same DATABASE_URL as above (see AppDbContextFactory — no embedded defaults).
